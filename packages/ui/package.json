{
  "name": "@abdokouta/ts-ui",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "description": "Shared UI primitives — slot system, layout components, and composable patterns for @abdokouta packages",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json}\""
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    }
  },
  "devDependencies": {
    "@bprogress/react": "^1.2.7",
    "@nesvel/eslint-config": "^1.0.5",
    "@nesvel/prettier-config": "^1.0.3",
    "@nesvel/typescript-config": "^1.0.4",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "@vitest/ui": "^4.1.2",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "react": "^19.0.0",
    "tsup": "^8.5.1",
    "typescript": "6.0.2",
    "vitest": "^4.1.2"
  }
}
