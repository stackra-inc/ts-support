{
  "mcpServers": {
    "heroui-react": {
      "command": "npx",
      "args": ["-y", "@heroui/react-mcp@latest"],
      "disabled": false,
      "autoApprove": [
        "list_components",
        "get_component_docs",
        "get_component_source_code",
        "get_component_source_styles",
        "get_theme_variables",
        "get_docs"
      ]
    },
    "upstash": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/mcp-server@latest",
        "--email",
        "akouta66@gmail.com",
        "--api-key",
        "7cc28e73-5bbf-4b6b-bce9-1e0c9ad03bb4"
      ],
      "disabled": false,
      "autoApprove": [
        "redis_database_get_details",
        "redis_database_run_redis_commands"
      ]
    },
    "npm-package-docs": {
