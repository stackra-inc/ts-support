# ==============================================================================
# Vite Application Configuration
# ==============================================================================
# This file documents every environment variable accepted by the Vite app.
# Copy this file to .env.development, .env.staging, or .env.production
# and fill in the values for each environment.
#
# Rules:
#   - Variables prefixed with VITE_ are exposed to the browser bundle.
#   - Variables WITHOUT the VITE_ prefix are server-side only (SSR / Node).
#   - Never put secrets in VITE_ variables — they are public.
#
# NEVER commit .env.development, .env.staging, or .env.production to git.
# Only .env.example is tracked.
# ==============================================================================


# ==============================================================================
# APPLICATION
# ==============================================================================

VITE_APP_NAME=Pixielity
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# Supported: development | staging | production
NODE_ENV=development


# ==============================================================================
# API
# ==============================================================================

# Base URL for all API requests — exposed to the browser.
VITE_API_BASE_URL=http://localhost:8080
VITE_API_VERSION=v1

# Request timeouts in milliseconds.
VITE_API_TIMEOUT_MS=30000

# Maximum number of retry attempts on failure.
VITE_API_MAX_RETRIES=3


# ==============================================================================
# AUTHENTICATION
# ==============================================================================

# Supported: jwt | oauth2 | apiKey | none
VITE_AUTH_STRATEGY=jwt

# OAuth2 / OIDC (only required when VITE_AUTH_STRATEGY=oauth2)
VITE_AUTH_OAUTH2_CLIENT_ID=
VITE_AUTH_OAUTH2_REDIRECT_URI=
VITE_AUTH_OAUTH2_AUTH_ENDPOINT=
VITE_AUTH_OAUTH2_TOKEN_ENDPOINT=
VITE_AUTH_OAUTH2_SCOPES=openid,profile,email

# Session timeout in seconds.
VITE_AUTH_SESSION_TIMEOUT_S=86400


# ==============================================================================
# ANALYTICS
# ==============================================================================

VITE_ANALYTICS_ENABLED=false
VITE_ANALYTICS_CRASH_ENABLED=false

# Provider keys — only set the ones you use.
VITE_ANALYTICS_GA_MEASUREMENT_ID=
VITE_ANALYTICS_MIXPANEL_TOKEN=
VITE_ANALYTICS_AMPLITUDE_API_KEY=
VITE_ANALYTICS_SEGMENT_WRITE_KEY=
VITE_ANALYTICS_POSTHOG_API_KEY=
VITE_ANALYTICS_POSTHOG_HOST=https://app.posthog.com

# Sentry DSN — leave empty to disable.
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1


# ==============================================================================
# FEATURE FLAGS
# ==============================================================================

VITE_FLAG_NEW_ONBOARDING=false
VITE_FLAG_AI_ASSISTANT=false
VITE_FLAG_PREMIUM_THEMES=false
VITE_FLAG_NEW_DASHBOARD=false

# Remote feature flag provider
# Supported: none | launchDarkly | unleash | posthog | custom
VITE_FLAGS_REMOTE_PROVIDER=none
VITE_FLAGS_REMOTE_SDK_KEY=
VITE_FLAGS_REMOTE_ENDPOINT=


# ==============================================================================
# WEBSOCKETS / REALTIME
# ==============================================================================

VITE_WS_ENABLED=false
VITE_WS_URL=ws://localhost:6001

# Laravel Reverb / Pusher
VITE_REVERB_APP_KEY=
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=6001
VITE_REVERB_SCHEME=ws


# ==============================================================================
# STORAGE
# ==============================================================================

# LocalStorage / IndexedDB key prefix.
VITE_STORAGE_KEY_PREFIX=pixielity


# ==============================================================================
# LOGGING
# ==============================================================================

# Supported: verbose | debug | info | warning | error | none
VITE_LOG_LEVEL=verbose

# Remote log endpoint — leave empty to disable.
VITE_LOG_REMOTE_ENDPOINT=
VITE_LOG_REMOTE_API_KEY=


# ==============================================================================
# THIRD-PARTY SERVICES
# ==============================================================================

# Add your third-party service keys here.
# VITE_STRIPE_PUBLISHABLE_KEY=
# VITE_GOOGLE_MAPS_API_KEY=
# VITE_RECAPTCHA_SITE_KEY=


# ==============================================================================
# UPSTASH REDIS (HTTP — browser-compatible)
# ==============================================================================
# Get credentials from https://console.upstash.com
# These are VITE_ prefixed so they're available in the browser bundle.
# Upstash REST tokens are scoped and rate-limited — safe to expose.

VITE_UPSTASH_REDIS_REST_URL=
VITE_UPSTASH_REDIS_REST_TOKEN=

# Optional: separate connections for cache and session
VITE_UPSTASH_CACHE_REST_URL=
VITE_UPSTASH_CACHE_REST_TOKEN=
VITE_UPSTASH_SESSION_REST_URL=
VITE_UPSTASH_SESSION_REST_TOKEN=

# Default Redis connection name
VITE_REDIS_DEFAULT_CONNECTION=main


# ==============================================================================
# CACHE
# ==============================================================================

# Cache driver: memory | redis | null
VITE_CACHE_DRIVER=memory
VITE_CACHE_PREFIX=app_
VITE_CACHE_MEMORY_MAX_SIZE=100
VITE_CACHE_MEMORY_TTL=300
VITE_CACHE_REDIS_PREFIX=cache_
VITE_CACHE_REDIS_TTL=3600
